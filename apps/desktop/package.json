{
  "name": "memories-desktop",
  "description": "Capture and retrieve work memories by voice",
  "author": "diogopaesdev",
  "version": "0.0.11",
  "private": true,
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@projectsreport/shared": "*",
    "electron-store": "^8.2.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "35.1.2",
    "electron-builder": "^25.1.8",
    "lucide-react": "^0.479.0",
    "postcss": "^8.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.0.14",
    "typescript": "^5.7.3",
    "vite": "^6.2.2",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.memories.desktop",
    "productName": "Memories",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "public/icon.png",
      "minimumSystemVersion": "13.0"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  }
}