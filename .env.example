# ============================================================
# Web App (apps/web/.env.local)
# ============================================================

# Better Auth
BETTER_AUTH_SECRET=your-secret-here-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Firebase Admin (service account JSON stringified)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# AI for voice processing (optional, falls back to raw transcript)
OPENAI_API_KEY=your-openai-api-key

# Public env (exposed to client)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id

# ============================================================
# Desktop App (apps/desktop/.env)
# ============================================================

VITE_WEB_APP_URL=http://localhost:3000
VITE_GOOGLE_CLIENT_ID=your-google-client-id
